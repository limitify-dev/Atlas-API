# ============================================
# Atlas API Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# Application Configuration
# ============================================
PORT=4000
NODE_ENV=production

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://myuser:mypassword@db.example.com:5432/atlas?schema=public
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas?schema=public"
POSTGRES_DB="atlas"
POSTGRES_USER="atlas"
POSTGRES_PASSWORD="atlas"
POSTGRES_PORT=5432

# ============================================
# Supabase Configuration
# ============================================
# Get these from your Supabase project settings
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-anon-or-service-key"

# ============================================
# JWT Configuration (Optional)
# ============================================
# Uncomment and set if your app uses JWT authentication
# JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
# JWT_EXPIRES_IN="7d"

# ============================================
# Redis Configuration
# ============================================
# Redis connection URL for BullMQ queues and Socket.io
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ============================================
# Push Notifications Configuration
# ============================================
# Expo Push Notifications (mobile)
# No key needed - uses Expo's free push service

# Firebase Cloud Messaging (web push) - Optional for Phase 1
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"

# ============================================
# CORS Configuration (Optional)
# ============================================
# Uncomment to restrict CORS origins
# CORS_ORIGIN="https://yourdomain.com,https://app.yourdomain.com"
