  PENDING_VERIFICATION
  PAID
  REJECTED
  CANCELLED
}

enum PaymentSubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PaymentPromiseStatus {
  ACTIVE
  FULFILLED
  OVERDUE
}

enum AcademicWindowType {
  TERM                // Main school term boundaries
  EXAM                // Exam sitting period
  GRADE_SUBMISSION    // Window when teachers may submit/edit grades
  REPORT_PUBLICATION  // When report cards become visible to parents
  ENROLLMENT          // Student enrollment / registration period
  HOLIDAY             // School break / public holiday block
  CONSULTATION        // Parent-teacher meeting period
  ASSIGNMENT          // Assignment creation / submission period
  CUSTOM              // Any other school-defined window
}

enum AcademicWindowStatus {
  DRAFT     // Being configured — not yet visible to staff/parents
  ACTIVE    // Window is open and in effect
  CLOSED    // Window has ended
  CANCELLED // Abandoned before activation
}
