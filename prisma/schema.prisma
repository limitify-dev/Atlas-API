  PRAISE
  DETENTION
}

enum IncidentStatus {
  ACTIVE
  IN_PROGRESS
  RESOLVED
}

enum PointTransactionType {
  DEDUCTION
  ADDITION
  RESET
  INITIAL
}

enum SchoolLevel {
  PRIMARY
  SENIOR
  NURSERY
}

enum EducationLevel {
