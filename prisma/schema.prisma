generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                       String                    @id @default(uuid())
  name                     String
  slug                     String                    @unique
  domain                   String?                   @unique
  logo                     String?
  address                  String?
  city                     String?
  state                    String?
  country                  String?
  zipCode                  String?
  phone                    String?
  email                    String?
  website                  String?
  status                   TenantStatus              @default(TRIAL)
  subscriptionPlan         SubscriptionPlan          @default(FREE)
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?
  maxStudents              Int                       @default(100)
  maxTeachers              Int                       @default(20)
  settings                 Json?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  timezone                 String                    @default("UTC")
  brandColor               String?                   @default("#1e40af")
  announcements            Announcement[]
  attendances              Attendance[]
  bookCopies               BookCopy[]
  bookTransactions         BookTransaction[]
  books                    Book[]
  cardLogs                 CardLog[]
  cardPermissions          CardPermission[]
  cards                    Card[]
  combinations             Combination[]
  conductPointTransactions ConductPointTransaction[]
  conductRecords           ConductRecord[]
  conversations            Conversation[]
  deviceLogs               DeviceLog[]
  devices                  Device[]
  events                   Event[]
  grades                   Grade[]
  academicTimelines        AcademicTimeline[]
  invoices                 Invoice[]
  messages                 Message[]
  promotions               Promotion[]
  notifications            Notification[]
  parents                  Parent[]
  invites                  Invite[]
  paymentPromises          PaymentPromise[]
  paymentSubmissions       PaymentSubmission[]
  permissionUsages         PermissionUsage[]
  permissions              Permission[]
  sections                 Section[]
  staff                    Staff[]
  studentConductPoints     StudentConductPoints[]
  studentGrades            StudentGrade[]
  students                 Student[]
  subjects                 Subject[]
  teacherAttendances       TeacherAttendance[]
  teachers                 Teacher[]
  users                    User[]

  @@index([slug])
  @@index([status])
  @@index([subscriptionPlan])
  @@map("tenants")
}

model User {
  id                       String                    @id @default(uuid())
  tenantId                 String?
  email                    String?                   @unique
  name                     String
  password                 String
  phone                    String?                   @unique
  avatar                   String?
  role                     Role                      @default(USER)
  userType                 UserType?
  status                   Status                    @default(PENDING)
  emailVerified            Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  lastLoginAt              DateTime?
  passwordChangedAt        DateTime?
  username                 String                    @unique
  sentAnnouncements        Announcement[]
  chatMessages             ChatMessage[]
  conductRecordsReported   ConductRecord[]
  conversationParticipants ConversationParticipant[]
  receivedMessages         Message[]                 @relation("MessageReceiver")
  sentMessages             Message[]                 @relation("MessageSender")
  receivedNotifications    NotificationRecipient[]
  sentNotifications        Notification[]
  parent                   Parent?
  pushTokens               PushToken[]
  refreshTokens            RefreshToken[]
  sessions                 Session[]
  staff                    Staff?
  student                  Student?
  teacher                  Teacher?
  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([userType])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Student {
  id                  String                @id @default(uuid())
  tenantId            String
  userId              String?               @unique
  studentId           String
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              Gender
  bloodGroup          String?
  nationality         String?
  address             String?
  photoUrl            String?
  rollNumber          String?
  admissionDate       DateTime
  gradeId             String
  sectionId           String
  promotionId         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  email               String?
  phone               String?
  attendances         Attendance[]
  borrowedBooks       BookTransaction[]
  card                Card?
  conductRecords      ConductRecord[]
  invoices            Invoice[]
  permissions         Permission[]
  conductPoints       StudentConductPoints?
  parents             StudentParent[]
  studentGrades       StudentGrade[]
  grade               Grade                 @relation(fields: [gradeId], references: [id])
  promotion           Promotion?            @relation(fields: [promotionId], references: [id])
  section             Section               @relation(fields: [sectionId], references: [id])
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([userId])
  @@index([studentId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([promotionId])
  @@map("students")
}

model Parent {
  id           String          @id @default(uuid())
  tenantId     String
  userId       String          @unique
  firstName    String
  lastName     String
  relationship String?
  occupation   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     StudentParent[]

  @@index([tenantId])
  @@index([userId])
  @@map("parents")
}

model StudentParent {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
  @@map("student_parents")
}

model Teacher {
  id             String              @id @default(uuid())
  tenantId       String
  userId         String              @unique
  teacherId      String
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  gender         Gender?
  qualification  String?
  specialization String?
  joiningDate    DateTime
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  department     String?
  photoUrl       String?
  card           Card?
  classes        ClassTeacher[]
  conductRecords ConductRecord[]
  subjects       SubjectTeacher[]
  attendances    TeacherAttendance[]
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, teacherId])
  @@index([tenantId])
  @@index([userId])
  @@index([teacherId])
  @@map("teachers")
}

model Grade {
  id             String         @id @default(uuid())
  tenantId       String
  name           String
  level          Int
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  code           String
  schoolLevel    SchoolLevel
  educationLevel EducationLevel
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections       Section[]
  students       Student[]
  subjects       Subject[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@index([schoolLevel])
  @@index([educationLevel])
  @@map("grades")
}

model Combination {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  subjectIds  Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections    Section[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@map("combinations")
}

model Section {
  id               String            @id @default(uuid())
  tenantId         String
  name             String
  gradeId          String
  promotionId      String?
  capacity         Int               @default(40)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  combinationId    String?
  division         String?
  isActive         Boolean           @default(true)
  bookTransactions BookTransaction[]
  classes          ClassTeacher[]
  combination      Combination?      @relation(fields: [combinationId], references: [id])
  grade            Grade             @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  promotion        Promotion?        @relation(fields: [promotionId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students         Student[]
  conversations    Conversation[]

  @@unique([tenantId, gradeId, name])
  @@index([tenantId])
  @@index([gradeId])
  @@index([combinationId])
  @@index([promotionId])
  @@map("sections")
}

model Subject {
  id            String           @id @default(uuid())
  tenantId      String
  name          String
  code          String
  description   String?
  gradeId       String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  studentGrades StudentGrade[]
  teachers      SubjectTeacher[]
  grade         Grade            @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([gradeId])
  @@index([code])
  @@map("subjects")
}

model ClassTeacher {
  id        String   @id @default(uuid())
  teacherId String
  sectionId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, sectionId])
  @@index([teacherId])
  @@index([sectionId])
  @@map("class_teachers")
}

model SubjectTeacher {
  id        String   @id @default(uuid())
  teacherId String
  subjectId String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
  @@map("subject_teachers")
}

model Attendance {
  id          String           @id @default(uuid())
  tenantId    String
  studentId   String
  status      AttendanceStatus
  remarks     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  checkInTime DateTime?
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, studentId, createdAt])
  @@map("attendances")
}

model TeacherAttendance {
  id           String           @id @default(uuid())
  tenantId     String
  teacherId    String
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  remarks      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  teacher      Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([teacherId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, teacherId, createdAt])
  @@map("teacher_attendances")
}

model Book {
  id              String            @id @default(uuid())
  tenantId        String
  title           String
  author          String
  isbn            String
  publisher       String?
  publicationYear Int?
  category        String
  totalCopies     Int               @default(1)
  availableCopies Int               @default(1)
  description     String?
  imageUrl        String?
  status          BookStatus        @default(AVAILABLE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  price           Float             @default(0)
  copies          BookCopy[]
  transactions    BookTransaction[]
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, isbn])
  @@index([tenantId])
  @@index([isbn])
  @@index([category])
  @@index([status])
  @@map("books")
}

model BookCopy {
  id           String            @id @default(uuid())
  tenantId     String
  bookId       String
  code         String
  shelf        String?
  status       BookStatus        @default(AVAILABLE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  book         Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions BookTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([bookId])
  @@index([status])
  @@index([shelf])
  @@map("book_copies")
}

model BookTransaction {
  id         String    @id @default(uuid())
  tenantId   String
  bookId     String
  studentId  String?
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float?    @default(0)
  remarks    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookCopyId String?
  sectionId  String?
  bookCopy   BookCopy? @relation(fields: [bookCopyId], references: [id], onDelete: Cascade)
  book       Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section    Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student    Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bookId])
  @@index([bookCopyId])
  @@index([studentId])
  @@index([sectionId])
  @@index([issueDate])
  @@index([returnDate])
  @@map("book_transactions")
}

model Permission {
  id             String                @id @default(uuid())
  tenantId       String
  studentId      String
  requestDate    DateTime              @default(now())
  fromDate       DateTime
  toDate         DateTime
  reason         String
  status         PermissionStatus      @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  remarks        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  fromTime       String?
  permissionType PermissionType        @default(ONE_TIME)
  qrCode         String?
  qrCodeUsed     Boolean               @default(false)
  requestedBy    PermissionRequestedBy @default(ADMIN)
  requestedById  String
  schedule       Json?
  title          String?
  toTime         String?
  usedAt         DateTime?
  usages         PermissionUsage[]
  student        Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([status])
  @@index([permissionType])
  @@index([fromDate, toDate])
  @@index([qrCodeUsed])
  @@map("permissions")
}

model PermissionUsage {
  id           String     @id @default(uuid())
  tenantId     String
  permissionId String
  usedAt       DateTime   @default(now())
  checkoutTime DateTime
  location     String?
  cardLogId    String?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([permissionId])
  @@index([usedAt])
  @@map("permission_usages")
}

model ConductRecord {
  id                String                    @id @default(uuid())
  tenantId          String
  studentId         String
  type              ConductType
  description       String
  date              DateTime                  @default(now())
  reportedBy        String?
  severity          Int                       @default(1)
  actionTaken       String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  incidentStatus    IncidentStatus            @default(ACTIVE)
  pointsDeducted    Int?
  resolutionNotes   String?
  resolvedAt        DateTime?
  resolvedBy        String?
  reportedByUserId  String?
  pointTransactions ConductPointTransaction[]
  reportedByUser    User?                     @relation(fields: [reportedByUserId], references: [id])
  teacher           Teacher?                  @relation(fields: [reportedBy], references: [id])
  student           Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([type])
  @@index([date])
  @@index([incidentStatus])
  @@map("conduct_records")
}

model StudentConductPoints {
  id            String                    @id @default(uuid())
  tenantId      String
  studentId     String                    @unique
  currentPoints Int                       @default(100)
  lastUpdatedAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  transactions  ConductPointTransaction[]
  student       Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([currentPoints])
  @@map("student_conduct_points")
}

model ConductPointTransaction {
  id                     String               @id @default(uuid())
  tenantId               String
  studentConductPointsId String
  conductRecordId        String?
  transactionType        PointTransactionType
  pointsChange           Int
  pointsBefore           Int
  pointsAfter            Int
  reason                 String
  recordedBy             String
  recordedAt             DateTime             @default(now())
  conductRecord          ConductRecord?       @relation(fields: [conductRecordId], references: [id])
  studentConductPoints   StudentConductPoints @relation(fields: [studentConductPointsId], references: [id], onDelete: Cascade)
  tenant                 Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentConductPointsId])
  @@index([conductRecordId])
  @@index([recordedAt])
  @@index([transactionType])
  @@map("conduct_point_transactions")
}

model Conversation {
  id            String                    @id @default(uuid())
  tenantId      String
  type          ConversationType          @default(DIRECT)
  name          String?
  description   String?
  avatar        String?
  sectionId     String?
  createdBy     String?
  isReadOnly    Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  status        ConversationStatus        @default(ACTIVE)
  lastMessageAt DateTime?
  messages      ChatMessage[]
  participants  ConversationParticipant[]
  section       Section?                  @relation(fields: [sectionId], references: [id])
  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([sectionId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String           @id @default(uuid())
  conversationId String
  userId         String
  role           ConversationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())
  lastReadAt     DateTime?
  isMuted        Boolean          @default(false)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType  @default(TEXT)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model PushToken {
  id        String       @id @default(uuid())
  userId    String
  token     String       @unique
  platform  PushPlatform
  deviceId  String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Message {
  id         String   @id @default(uuid())
  tenantId   String
  senderId   String
  receiverId String
  subject    String?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@map("messages")
}

model Announcement {
  id          String                  @id @default(uuid())
  tenantId    String
  title       String
  content     String
  imageUrl    String?
  ctaLabel    String?
  ctaType     String?
  ctaUrl      String?
  priority    String                  @default("NORMAL")
  publishedBy String
  publishedAt DateTime                @default(now())
  expiresAt   DateTime?
  isPinned    Boolean                 @default(false)
  audience    String                  @default("ALL")
  status      AnnouncementStatus      @default(ACTIVE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  publisher   User                    @relation(fields: [publishedBy], references: [id])
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipients  NotificationRecipient[]

  @@index([tenantId])
  @@index([publishedBy])
  @@index([publishedAt])
  @@index([status])
  @@map("announcements")
}

model Notification {
  id         String                  @id @default(uuid())
  tenantId   String
  userId     String
  title      String
  message    String
  type       String
  data       Json?
  createdAt  DateTime                @default(now())
  recipients NotificationRecipient[]
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("notifications")
}

model NotificationRecipient {
  id             String        @id @default(uuid())
  notificationId String?
  announcementId String?
  userId         String
  isRead         Boolean       @default(false)
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notification_recipients")
}

model Card {
  id          String           @id @default(uuid())
  tenantId    String
  cardNumber  String
  cardType    CardType
  status      CardStatus       @default(INACTIVE)
  issuedDate  DateTime         @default(now())
  expiryDate  DateTime?
  lastUsedAt  DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  studentId   String?          @unique
  teacherId   String?          @unique
  logs        CardLog[]
  permissions CardPermission[]
  student     Student?         @relation(fields: [studentId], references: [id])
  teacher     Teacher?         @relation(fields: [teacherId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cardNumber])
  @@index([tenantId])
  @@index([cardNumber])
  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([cardType])
  @@map("cards")
}

model CardLog {
  id          String   @id @default(uuid())
  tenantId    String
  cardId      String
  action      String
  location    String?
  description String?
  performedBy String?
  createdAt   DateTime @default(now())
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cardId])
  @@index([action])
  @@index([createdAt])
  @@map("card_logs")
}

model CardPermission {
  id         String    @id @default(uuid())
  tenantId   String
  cardId     String
  permission String
  isGranted  Boolean   @default(true)
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  card       Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cardId])
  @@index([permission])
  @@index([isGranted])
  @@map("card_permissions")
}

model Event {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String?
  eventDate   DateTime
  location    String?
  organizer   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventDate])
  @@map("events")
}

model AcademicExam {
  id          String               @id @default(uuid())
  tenantId    String
  title       String
  description String?
  term        String?
  examDate    DateTime
  gradeId     String
  sectionId   String?
  subjectId   String?
  status      AcademicRecordStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([tenantId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([examDate])
  @@map("academic_exams")
}

model AcademicAssignment {
  id          String               @id @default(uuid())
  tenantId    String
  courseId    String?
  title       String
  description String?
  term        String?
  dueDate     DateTime
  gradeId     String
  sectionId   String?
  subjectId   String?
  maxScore    Float                @default(100)
  status      AcademicRecordStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([tenantId])
  @@index([courseId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([dueDate])
  @@map("academic_assignments")
}

model AcademicCourse {
  id          String               @id @default(uuid())
  tenantId    String
  teacherId   String
  sectionId   String
  subjectId   String
  title       String
  code        String?
  term        String?
  description String?
  status      AcademicRecordStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([teacherId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([status])
  @@map("academic_courses")
}

model AcademicAssignmentResult {
  id           String                 @id @default(uuid())
  tenantId     String
  assignmentId String
  studentId    String
  score        Float?
  remarks      String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  status       AssignmentResultStatus @default(PENDING)
  createdBy    String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([assignmentId, studentId])
  @@index([tenantId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("academic_assignment_results")
}

model AcademicReportCard {
  id           String               @id @default(uuid())
  tenantId     String
  studentId    String
  term         String
  overallScore Float?
  grade        String?
  remarks      String?
  publishedAt  DateTime?
  publishedBy  String
  status       AcademicRecordStatus @default(DRAFT)
  metadata     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([tenantId, studentId, term])
  @@index([tenantId])
  @@index([studentId])
  @@index([term])
  @@map("academic_report_cards")
}

model ConsultationBooking {
  id               String             @id @default(uuid())
  tenantId         String
  consultationDate DateTime
  startTime        String
  endTime          String
  studentId        String
  teacherId        String
  parentId         String?
  sectionId        String?
  location         String?
  announcementId   String?
  notes            String?
  status           ConsultationStatus @default(SCHEDULED)
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId])
  @@index([consultationDate])
  @@index([teacherId])
  @@index([studentId])
  @@index([parentId])
  @@map("consultation_bookings")
}

model Device {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  deviceType  DeviceType
  location    String?
  description String?
  apiKey      String       @unique
  apiKeyHash  String
  status      DeviceStatus @default(INACTIVE)
  lastSeenAt  DateTime?
  ipAddress   String?
  metadata    Json?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  logs        DeviceLog[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([apiKey])
  @@index([status])
  @@index([deviceType])
  @@index([lastSeenAt])
  @@map("devices")
}

model DeviceLog {
  id          String   @id @default(uuid())
  tenantId    String
  deviceId    String
  action      String
  description String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deviceId])
  @@index([action])
  @@index([createdAt])
  @@map("device_logs")
}

model SystemLog {
  id         String   @id @default(uuid())
  level      LogLevel
  message    String
  metadata   Json?
  userId     String?
  tenantId   String?
  ipAddress  String?
  userAgent  String?
  endpoint   String?
  method     String?
  statusCode Int?
  duration   Int?
  createdAt  DateTime @default(now())

  @@index([level])
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([endpoint])
  @@map("system_logs")
}

// ─── NEW MODELS ──────────────────────────────────────────────────────────────

model AcademicTimeline {
  id           String               @id @default(uuid())
  tenantId     String
  name         String               // e.g. "Term 1 Grade Submission Window"
  type         AcademicWindowType
  academicYear String               // e.g. "2024-2025"
  term         String?              // e.g. "T1", "T2", "S1" — null = applies to full year
  startDate    DateTime
  endDate      DateTime
  description  String?
  gradeIds     Json?                // string[] | null — null means applies to all grades
  status       AcademicWindowStatus @default(DRAFT)
  createdBy    String               // userId of the staff member who set this
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([academicYear])
  @@index([status])
  @@index([startDate, endDate])
  @@index([tenantId, type, status])
  @@map("academic_timelines")
}

model Promotion {
  id          String    @id @default(uuid())
  tenantId    String
  name        String                // e.g. "Promotion 2023", "Class of 2028"
  entryYear   Int                   // year the cohort enrolled (e.g. 2023)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections    Section[]
  students    Student[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([entryYear])
  @@index([isActive])
  @@map("promotions")
}

model Staff {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String   @unique
  firstName   String
  lastName    String
  department  String?
  staffRole   String   // "finance" | "discipline" | "reception" | "IT" | custom
  photoUrl    String?
  joiningDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([staffRole])
  @@map("staff")
}

model StudentGrade {
  id         String   @id @default(uuid())
  tenantId   String
  studentId  String
  subjectId  String
  term       String   // e.g. "2025-T1"
  percentage Float
  comment    String?
  gradedBy   String   // userId of the teacher
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentId, subjectId, term])
  @@index([tenantId])
  @@index([studentId])
  @@index([term])
  @@map("student_grades")
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  studentId   String
  title       String
  description String?
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  dueDate     DateTime
  term        String?
  category    String?       // "tuition" | "transport" | "uniform" | custom
  status      InvoiceStatus @default(UNPAID)
  issuedBy    String        // userId of finance staff who created it
  lockedAt    DateTime?     // set when status = PENDING_VERIFICATION
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  student     Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions PaymentSubmission[]
  promises    PaymentPromise[]

  @@index([tenantId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@index([tenantId, studentId])
  @@map("invoices")
}

model PaymentSubmission {
  id            String                  @id @default(uuid())
  tenantId      String
  invoiceId     String
  submittedBy   String                  // userId (parent)
  proofUrl      String                  // Supabase storage URL
  note          String?
  amountClaimed Decimal?                @db.Decimal(10, 2)
  status        PaymentSubmissionStatus @default(PENDING_REVIEW)
  reviewedBy    String?                 // userId of finance staff
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
  @@map("payment_submissions")
}

model PaymentPromise {
  id           String               @id @default(uuid())
  tenantId     String
  invoiceId    String
  promisedBy   String               // userId (parent)
  promisedDate DateTime
  note         String?
  status       PaymentPromiseStatus @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
  @@index([promisedDate])
  @@map("payment_promises")
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

model Invite {
  id             String         @id @default(uuid())
  tenantId       String
  phone          String
  email          String?
  name           String?
  role           Role
  referenceId    String?
  token          String         @unique
  onboardingMode OnboardingMode @default(OTP)
  expiresAt      DateTime
  status         InviteStatus   @default(PENDING)
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@index([phone, tenantId])
  @@map("invites")
}

model OtpCode {
  id          String     @id @default(uuid())
  phone       String
  tenantId    String?
  inviteToken String?
  purpose     OtpPurpose @default(ONBOARDING)
  code        String
  expiresAt   DateTime
  attempts    Int        @default(0)
  verified    Boolean    @default(false)
  createdAt   DateTime   @default(now())

  @@index([phone])
  @@index([inviteToken])
  @@map("otp_codes")
}

